<div class="flex flex-col md:flex-row items-center gap-4 py-3 border-b">
  <div class="w-16 h-16 flex-none">
    <%= image_tag 'default_image.jpg', alt: 'Default Image', class: "w-full h-full object-cover rounded-lg shadow-sm" %>
  </div>

  <div class="w-full md:w-80 flex-none text-lg font-medium text-gray-900 text-center md:text-left">
    <%= @cart_item.product.name %>
  </div>

  <%= render CartItemQuantityButtonsComponent.new(cart_item: @cart_item) %>

  <div class="w-full md:w-20 flex-1 text-right text-lg font-semibold text-gray-700 md:text-left">
    <%= @cart_item.product.price %> ₽
  </div>
</div>
