<div id="toggle_cart_button_<%= @product.id %>">
  <% if @cart_item.present? %>
    <%= button_to 'Удалить из Корзину', cart_item_path(@cart_item), method: :delete, id: cart_button_id, data: { turbo_confirm: 'Удалить товар из корзины?' }, class: classes %>
  <% else %>
    <%= button_to 'В Корзину', cart_items_path(product_id: @product), method: :post, id: cart_button_id, class: classes %>
  <% end %>
</div>
