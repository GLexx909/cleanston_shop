<div class="container mx-auto p-4">
  <h1 class="text-2xl font-bold mb-4">Корзина</h1>
  <div class="space-x-4 py-2">
    <%= render CartItemComponent.with_collection(@cart_items) %>

    <div class="mt-8 pt-4">
      <div class="flex justify-between text-lg font-semibold text-gray-900">
        <span>Сумма заказа</span>
        <%= render CartFullSumComponent.new(cart: @cart) %>
      </div>

      <div class="mt-4">
        <%= button_to 'Оформить', root_path, class: 'w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-500 transition' %>
      </div>
    </div>
  </div>
</div>
